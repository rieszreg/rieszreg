#!/usr/bin/env bash
# Pre-commit hook for the rieszreg monorepo.
#
# Two checks:
#   1. Per-package API change without README / docs update.
#   2. Doc-tone lint on staged docs/*.qmd and README.md (added lines).
#
# Activate per clone with:  git config core.hooksPath .githooks
# Or run scripts/setup-hooks.sh.
# Bypass with:               git commit --no-verify
#
# The doc-tone lint is factored into .githooks/lint-docs.sh so CI runs the
# same check against the diff against base.

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

staged=$(git diff --cached --name-only)

# ----------------------------------------------------------------------
# Check 1: per-package API change without README / docs update.
#
# For each `packages/<pkg>/...` path in the staged diff, classify it as
# either "API code", "package-local docs/README", or "neither". If any
# package has API code changes but no README or docs update (locally OR
# in the unified docs/ site), block the commit.
# ----------------------------------------------------------------------

pkgs_api_changed=()
pkgs_docs_changed=()
unified_docs_changed=0

# Track which packages are touched at all.
touched_pkgs=$(echo "$staged" \
  | { grep -E '^packages/[^/]+/' || true; } \
  | cut -d/ -f2 \
  | sort -u)

for path in $staged; do
  case "$path" in
    docs/*.qmd|docs/_quarto.yml)
      unified_docs_changed=1
      ;;
  esac
done

for pkg in $touched_pkgs; do
  api_re="^packages/${pkg}/(python/${pkg}/(__init__|estimator|estimand|augmentation|losses|diagnostics|tracer)\\.py"
  api_re+="|python/${pkg}/(estimands|losses|backends|testing)/.*\\.py"
  api_re+="|r/${pkg}/R/.*\\.R"
  api_re+="|r/${pkg}/NAMESPACE"
  api_re+=")$"

  pkg_docs_re="^packages/${pkg}/(README\\.md|docs/.*\\.qmd)$"

  api_hits=$(echo "$staged" | grep -E "$api_re" || true)
  pkg_docs_hits=$(echo "$staged" | grep -E "$pkg_docs_re" || true)

  if [[ -n "$api_hits" ]]; then
    pkgs_api_changed+=("$pkg")
    if [[ -n "$pkg_docs_hits" || $unified_docs_changed -eq 1 ]]; then
      pkgs_docs_changed+=("$pkg")
    fi
  fi
done

missing=()
for pkg in "${pkgs_api_changed[@]:-}"; do
  [[ -z "$pkg" ]] && continue
  found=0
  for done_pkg in "${pkgs_docs_changed[@]:-}"; do
    [[ "$pkg" == "$done_pkg" ]] && found=1 && break
  done
  if [[ $found -eq 0 ]]; then
    missing+=("$pkg")
  fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
  echo "ERROR: public-API change(s) without a README / docs update."
  echo
  echo "Affected package(s):"
  for pkg in "${missing[@]}"; do
    echo "  - $pkg"
  done
  echo
  echo "Update either docs/*.qmd (unified site) or"
  echo "packages/<pkg>/README.md / packages/<pkg>/docs/*.qmd, then"
  echo "re-stage and re-commit. On bilingual pages, update BOTH the"
  echo "{python} and {r} tabs."
  echo
  echo "If this change genuinely cannot affect docs (internal refactor,"
  echo "test-only, comment fix), bypass with: git commit --no-verify"
  exit 1
fi

# ----------------------------------------------------------------------
# Check 2: doc-tone lint on staged qmd / README.md.
# ----------------------------------------------------------------------

exec "$repo_root/.githooks/lint-docs.sh" --cached
